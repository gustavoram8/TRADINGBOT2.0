# Python backend URL (deploy to Railway / Render / Fly.io)
# Leave empty to use mock data
PYTHON_API_URL=https://your-python-backend.railway.app

# Google Gemini API key (for AI Analyst page)
GEMINI_API_KEY=your-gemini-api-key-here

# MongoDB (optional — Python backend handles this)
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/
